  "homepage": "https://github.com/Keiy78120/rex#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^1.3.24",
    "@langchain/core": "^1.1.31",
