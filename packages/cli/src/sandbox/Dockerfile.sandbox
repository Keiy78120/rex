FROM node:22-alpine

# Install Claude Code CLI + rex
RUN npm install -g @anthropic-ai/claude-code 2>/dev/null || true
RUN npm install -g tsx 2>/dev/null || true

# Create non-root user for additional isolation
RUN adduser -D -u 1001 rex
USER rex

WORKDIR /workspace

# Default command: show usage
CMD ["echo", "Usage: docker-compose run --rm runner <rex-command>"]
